{{! Sheet Header }}
<header class="sheet-header" style="
  {{#if avatarProperties.objectFit}} --avatar-object-fit: {{avatarProperties.objectFit}}; {{/if}}
  {{#if avatarProperties.objectPosition}} --avatar-object-position: {{avatarProperties.objectPosition}}; {{/if}}
  ">
  <img
    class="profile-img"
    src="{{document.img}}"
    alt="{{document.name}}"
    data-action="{{ifThen isPlay "showPortraitArtwork" "editImage"}}"
    {{#unless isPlay}}data-edit="img"{{/unless}}
    title="{{document.name}}"
  >
  <div class="header-center flexcol">
    <div class="document-name">
      {{#if isPlay}}
      <h2>{{document.name}}</h2>
      {{else}}
      {{formInput fields.name value=source.name placeholder=(localize "Name") }}
      {{/if}}
    </div>
    <div class="tags flexrow">
      {{!-- Keyword Tags --}}
      {{#each retainerKeywords as |keyword|}}
      <div class="tag">{{keyword}}</div>
      {{/each}}
      {{#if system.retainer.roleLabel}}
      <div class="tag">{{system.retainer.roleLabel}}</div>
      {{/if}}
      {{#unless isPlay}}
      <a data-action="editRetainerMetadata">
        <i class="fa-solid fa-gear"></i>
      </a>
      {{/unless}}
    </div>
  </div>
  <div class="header-right flexcol">
    <div class="actor-source">
      {{system.source.label}}
    </div>
  </div>
</header>
