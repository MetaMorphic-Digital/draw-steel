  "system": {
    "description": {
      "value": "<p>You possess wings powerful enough to take you airborne. While using your wings to fly, you can stay aloft for a number of rounds equal to [[lookup formula=\"max(@M, 1)\" evaluate=true]]{your Might score (minimum 1 round)} before you fall. While using your wings to fly at 3rd level or lower, you have damage weakness 5.</p>",
      "director": "<p>Two active effects are included in this feature. One for players in echelon 1, another for players in echelon 2+. Players should keep the one that applies.</p>"
    },
    "source": {
      "book": "Heroes",
