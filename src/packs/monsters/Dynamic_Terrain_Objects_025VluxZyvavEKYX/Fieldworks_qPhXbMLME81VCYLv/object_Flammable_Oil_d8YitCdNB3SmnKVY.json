      "img": "icons/commodities/tech/console-steel.webp",
      "system": {
        "description": {
          "value": "<p>As a maneuver, a creature adjacent to a patch of flammable oil can make an [[/test A]].</p><dl class=\"power-roll-display\"><dt class=\"tier1\"><p>!</p></dt><dd><p>The creature ignites the oil and is affected as if in its area.</p></dd><dt class=\"tier2\"><p>@</p></dt><dd><p>The oil temporarily ignites before safely burning out, and the creature takes [[/damage 3 fire]] damage and is [[/apply vOaw1Bd042DYUCow save]].</p></dd><dt class=\"tier3\"><p>#</p></dt><dd><p>The oil is rendered safe and can’t be ignited.</p></dd><p></p></dl><p></p>",
          "director": ""
        },
